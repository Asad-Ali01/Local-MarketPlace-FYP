{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "ignoreDeprecations":"6.0",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["node_modules/@types","./src/types"]
  },
  "include": ["src/types/**/*.d.ts", "src"],
  "exclude": ["node_modules"]
}